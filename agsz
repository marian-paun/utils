#!/usr/bin/env bash
set -euo pipefail
# agsz - bucket files by age and show counts and sizes

# Set the age ranges in days
ages=(0 1 3 7 15 30 60 90 180 270 365 730 1095 1460 1825)

# number of buckets is one less than number of thresholds
bucket_count=$(( ${#ages[@]} - 1 ))

# initialize arrays
counts=()
sizes=()

# collect counts and sizes for each age bucket
for ((i=0; i<bucket_count; i++)); do
  next=$((i + 1))
  lower=${ages[$i]}
  upper=${ages[$next]}

  if [[ $i -eq 0 ]]; then
    # files newer than upper days
    read -r cnt total < <(find . -type f -mtime "-${upper}" -printf '%s\n' | awk 'BEGIN{c=0;s=0} {c++; s+=$1} END{print c, s}')
  else
    # files between lower and upper days old
    read -r cnt total < <(find . -type f -mtime "-${upper}" -mtime +"${lower}" -printf '%s\n' | awk 'BEGIN{c=0;s=0} {c++; s+=$1} END{print c, s}')
  fi

  counts[i]=${cnt:-0}
  sizes[i]=${total:-0}
done

# print results
for ((i=0; i<bucket_count; i++)); do
  next=$((i + 1))
  cnt=${counts[i]}
  total=${sizes[i]}

  if [[ ${cnt} -gt 0 && ${total} -gt 0 ]]; then
    size_mb=$(awk -v s="${total}" 'BEGIN{printf "%.3f", s/1024/1024}')
    size_gb=$(awk -v s="${total}" 'BEGIN{printf "%.3f", s/1024/1024/1024}')
    gb_lt_1=$(awk -v g="${size_gb}" 'BEGIN{print (g < 1)}')

    if [[ "${gb_lt_1}" -eq 1 ]]; then
      printf "%'9d files between %4d and %4d days old, size: %'9.3f MB\n" "${cnt}" "${ages[$i]}" "${ages[$next]}" "${size_mb}"
    else
      printf "%'9d files between %4d and %4d days old, size: %'9.3f GB\n" "${cnt}" "${ages[$i]}" "${ages[$next]}" "${size_gb}"
    fi
  fi
done
