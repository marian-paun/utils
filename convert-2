#!/bin/bash

# ==============================================================================
# CONFIGURATION
# ==============================================================================
AUDIO_QUALITY="-q:a 2"
AUDIO_CODEC="aac"
OUTPUT_EXT="m4a"

# ==============================================================================
# HELPER FUNCTIONS
# ==============================================================================

# Find the best available cover art file in a directory.
find_cover_art() {
    local search_dir="$1"
    local cover=""
    # Prioritized list of common cover art filenames
    for pattern in "cover.jpg" "cover.jpeg" "cover.png" "folder.jpg" "folder.png" "front.jpg" "front.png" "*.jpg" "*.png"; do
        # Find the first file matching the pattern in the directory
        local found
        found=$(find "$search_dir" -maxdepth 1 -type f -iname "$pattern" -print -quit)
        if [[ -n "$found" ]]; then
            cover="$found"
            break
        fi
    done
    echo "$cover"
}

# Construct the part of the ffmpeg command responsible for adding cover art.
build_cover_art_args() {
    local input_file="$1"
    local cover_file="$2"
    local art_args=()

    # Check for embedded art first
    local has_embedded
    has_embedded=$(ffprobe -v quiet -select_streams v -show_entries stream=index -of csv=p=0 "$input_file" | head -n 1)

    if [[ -n "$has_embedded" ]]; then
        echo "Using embedded cover art." >&2
        art_args=(-map 0:a -map 0:v:0 -c:v copy -disposition:v:0 attached_pic)
    elif [[ -n "$cover_file" ]]; then
        echo "Using external cover: $(basename "$cover_file")" >&2
        art_args=(-i "$cover_file" -map 0:a -map 1:v -c:v mjpeg -disposition:v:0 attached_pic)
    else
        art_args=(-map 0:a)
    fi
    echo "${art_args[@]}"
}

# Convert a single audio file to the target format.
convert_single_file() {
    local input="$1"
    local output="$2"
    local cover_file="$3"
    local -n metadata_map="$4"

    if [[ -f "$output" ]]; then
        echo "Skipping (output exists: $(basename "$output"))" >&2
        return
    fi

    echo "Processing: $(basename "$input") -> $(basename "$output")" >&2

    # Base ffmpeg command
    local cmd=(ffmpeg -hide_banner -loglevel error -stats -y -i "$input")

    # Add metadata from info.txt if provided
    local info_metadata_args=()
    [[ -n "${metadata_map["Artist"]}" ]] && info_metadata_args+=("-metadata" "artist=${metadata_map["Artist"]}")
    [[ -n "${metadata_map["Album"]}" ]] && info_metadata_args+=("-metadata" "album=${metadata_map["Album"]}")
    [[ -n "${metadata_map["Year"]}" ]] && info_metadata_args+=("-metadata" "date=${metadata_map["Year"]}")
    [[ -n "${metadata_map["Genre"]}" ]] && info_metadata_args+=("-metadata" "genre=${metadata_map["Genre"]}")
    cmd+=("${info_metadata_args[@]}")

    # Get cover art arguments
    local art_args_str
    art_args_str=$(build_cover_art_args "$input" "$cover_file")
    local art_args
    read -r -a art_args <<< "$art_args_str"
    cmd+=("${art_args[@]}")

    # Add output options and final output file path
    cmd+=(-c:a "$AUDIO_CODEC" $AUDIO_QUALITY -map_metadata 0 -movflags +faststart "$output")

    # Execute the conversion
    if "${cmd[@]}"; then
        echo "Successfully finished: $(basename "$output")" >&2
    else
        echo "Error converting: $(basename "$input")" >&2
        [[ -f "$output" ]] && rm "$output"
    fi
}

# ==============================================================================
# SCRIPT MAIN LOGIC
# ==============================================================================

# 1. Get and validate input folder
SEARCH_DIR="${1:-.}"
if [[ ! -d "$SEARCH_DIR" ]]; then
    echo "Error: Directory '$SEARCH_DIR' does not exist." >&2
    exit 1
fi

# Determine temporary directory
TEMP_BASE_DIR="/tmp"
[[ -d "/temp" ]] && TEMP_BASE_DIR="/temp"

# 2. Check for required tools
for tool in ffmpeg ffprobe; do
    if ! command -v "$tool" >/dev/null 2>&1; then
        echo "Error: Required tool '$tool' is not installed." >&2
        exit 1
    fi
done

# 3. Discover all relevant files in the target directory
mapfile -d '' CUE_FILES < <(find "$SEARCH_DIR" -maxdepth 1 -type f -iname "*.cue" -print0)
mapfile -d '' FLAC_FILES < <(find "$SEARCH_DIR" -maxdepth 1 -type f -iname "*.flac" -print0 | sort -z)
mapfile -d '' MP3_FILES < <(find "$SEARCH_DIR" -maxdepth 1 -type f -iname "*.mp3" -print0 | sort -z)

NUM_CUE=${#CUE_FILES[@]}
NUM_FLAC=${#FLAC_FILES[@]}
NUM_MP3=${#MP3_FILES[@]}
NUM_AUDIO=$((NUM_FLAC + NUM_MP3))

# Parse info.txt for metadata
declare -A METADATA_FROM_INFO
INFO_FILE="$SEARCH_DIR/info.txt"
if [[ -f "$INFO_FILE" ]]; then
    while IFS='=' read -r key value; do
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | sed -e 's/^"//' -e 's/"$//' | xargs)
        [[ -n "$key" && -n "$value" ]] && METADATA_FROM_INFO["$key"]="$value"
    done < "$INFO_FILE"
fi

# 4. Handle scenarios
if [[ $NUM_CUE -eq 1 && $NUM_AUDIO -eq 1 ]]; then
    # --- CUE SHEET + SINGLE AUDIO FILE ---
    CUE_FILE="${CUE_FILES[0]}"
    AUDIO_FILE=""
    [[ $NUM_FLAC -eq 1 ]] && AUDIO_FILE="${FLAC_FILES[0]}" || AUDIO_FILE="${MP3_FILES[0]}"

    echo "Detected CUE sheet mode." >&2
    read -p "Split into individual tracks (s) or create a single file with chapters (c)? [s/c]: " choice
    dir=$(dirname "$AUDIO_FILE")
    cover=$(find_cover_art "$dir")

    case "$choice" in
        s|S)
            if ! command -v shnsplit >/dev/null 2>&1; then echo "Error: shnsplit required." >&2; exit 1; fi
            split_dir=$(mktemp -d -p "$TEMP_BASE_DIR")
            shnsplit -d "$split_dir" -f "$CUE_FILE" -t "%n - %t" -o flac "$AUDIO_FILE"
            for track_flac in "$split_dir"/*.flac; do
                filename=$(basename "$track_flac" .flac)
                output_file="$dir/$filename.$OUTPUT_EXT"
                convert_single_file "$track_flac" "$output_file" "$cover" METADATA_FROM_INFO
            done
            rm -r "$split_dir"
            ;;
        c|C)
            filename=$(basename "$AUDIO_FILE")
            output="$dir/${filename%.*}.$OUTPUT_EXT"
            metadata_file=$(mktemp -p "$TEMP_BASE_DIR")
            echo ";FFMETADATA1" > "$metadata_file"
            grep -E '^\s*PERFORMER|^\s*TITLE' "$CUE_FILE" | head -n 2 | \
            sed -E 's/\r//g; s/^\s*PERFORMER\s*"(.*)"/artist=\1/g; s/^\s*TITLE\s*"(.*)"/album=\1/g' >> "$metadata_file"
            [[ -n "${METADATA_FROM_INFO["Year"]}" ]] && echo "date=${METADATA_FROM_INFO["Year"]}" >> "$metadata_file"
            [[ -n "${METADATA_FROM_INFO["Genre"]}" ]] && echo "genre=${METADATA_FROM_INFO["Genre"]}" >> "$metadata_file"
            
            export AUDIO_FILE
            awk '
                function time_to_ms(time_str) {
                    split(time_str, time, ":");
                    return (time[1] * 60 + time[2]) * 1000 + (time[3] * 1000 / 75);
                }
                { sub(/\r$/, ""); }
                /^[[:space:]]*TITLE[[:space:]]+/ {
                    t = $0; sub(/^[[:space:]]*TITLE[[:space:]]*"/, "", t); sub(/"[[:space:]]*$/, "", t); current_title = t;
                }
                /^[[:space:]]*INDEX[[:space:]]*01[[:space:]]+/ {
                    current_start_str = $0; sub(/^[[:space:]]*INDEX[[:space:]]*01[[:space:]]+/, "", current_start_str);
                    current_start_ms = time_to_ms(current_start_str);
                    if (last_start_ms != "") {
                        print "\n[CHAPTER]";
                        print "TIMEBASE=1/1000";
                        printf "START=%.0f\n", last_start_ms;
                        printf "END=%.0f\n", current_start_ms - 1;
                        print "title=" last_title;
                    }
                    last_start_ms = current_start_ms; last_title = current_title;
                }
                END {
                    if (last_start_ms != "") {
                        print "\n[CHAPTER]";
                        print "TIMEBASE=1/1000";
                        printf "START=%.0f\n", last_start_ms;
                        cmd = "ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 \"" ENVIRON["AUDIO_FILE"] "\"";
                        cmd | getline duration_s; close(cmd);
                        printf "END=%.0f\n", duration_s * 1000;
                        print "title=" last_title;
                    }
                }
            ' "$CUE_FILE" >> "$metadata_file"

            cmd=(ffmpeg -nostdin -hide_banner -loglevel error -stats -y -i "$AUDIO_FILE" -i "$metadata_file")
            if [[ -n "$cover" ]]; then
                cmd+=(-i "$cover" -map 0:a -map 2:v -c:v mjpeg -disposition:v:0 attached_pic -map_metadata 1 -map_chapters 1)
            else
                has_embedded=$(ffprobe -v quiet -select_streams v -show_entries stream=index -of csv=p=0 "$AUDIO_FILE" | head -n 1)
                if [[ -n "$has_embedded" ]]; then
                    cmd+=(-map 0:a -map 0:v:0 -c:v copy -disposition:v:0 attached_pic -map_metadata 1 -map_chapters 1)
                else
                    cmd+=(-map 0:a -map_metadata 1 -map_chapters 1)
                fi
            fi
            cmd+=(-c:a "$AUDIO_CODEC" $AUDIO_QUALITY -movflags +faststart "$output")
            "${cmd[@]}" && rm "$metadata_file" || rm "$metadata_file" "$output"
            ;;
    esac

elif [[ $NUM_AUDIO -gt 1 ]]; then
    # --- MULTIPLE AUDIO FILES ---
    mapfile -d '' ALL_AUDIO < <(find "$SEARCH_DIR" -maxdepth 1 -type f \( -iname "*.flac" -o -iname "*.mp3" \) -print0 | sort -z)
    echo "Found $NUM_AUDIO audio files." >&2
    read -p "Convert to multiple files (m) or a single chapterized file (c)? [m/c]: " choice

    if [[ "$choice" == "c" || "$choice" == "C" ]]; then
        # MERGE INTO SINGLE CHAPTERIZED FILE
        album_name=$(basename "$(realpath "$SEARCH_DIR")")
        [[ -n "${METADATA_FROM_INFO["Album"]}" ]] && album_name="${METADATA_FROM_INFO["Album"]}"
        output="$SEARCH_DIR/$album_name.$OUTPUT_EXT"
        
        metadata_file=$(mktemp -p "$TEMP_BASE_DIR")
        concat_file=$(mktemp -p "$TEMP_BASE_DIR")
        echo ";FFMETADATA1" > "$metadata_file"
        [[ -n "${METADATA_FROM_INFO["Artist"]}" ]] && echo "artist=${METADATA_FROM_INFO["Artist"]}" >> "$metadata_file"
        echo "album=$album_name" >> "$metadata_file"
        [[ -n "${METADATA_FROM_INFO["Year"]}" ]] && echo "date=${METADATA_FROM_INFO["Year"]}" >> "$metadata_file"
        [[ -n "${METADATA_FROM_INFO["Genre"]}" ]] && echo "genre=${METADATA_FROM_INFO["Genre"]}" >> "$metadata_file"

        current_time_ms=0
        for f in "${ALL_AUDIO[@]}"; do
            echo "file '$(realpath "$f")'" >> "$concat_file"
            
            title=$(ffprobe -v error -show_entries format_tags=title -of default=noprint_wrappers=1:nokey=1 "$f" | tr -d '\r')
            [[ -z "$title" ]] && title=$(basename "$f" | sed 's/\.[^.]*$//')
            
            duration_s=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$f")
            duration_ms=$(echo "$duration_s * 1000 / 1" | bc)
            
            end_time_ms=$((current_time_ms + duration_ms))
            
            echo -e "\n[CHAPTER]\nTIMEBASE=1/1000\nSTART=$current_time_ms\nEND=$((end_time_ms - 1))\ntitle=$title" >> "$metadata_file"
            current_time_ms=$end_time_ms
        done

        cover=$(find_cover_art "$SEARCH_DIR")
        cmd=(ffmpeg -f concat -safe 0 -i "$concat_file" -i "$metadata_file")
        if [[ -n "$cover" ]]; then
            cmd+=(-i "$cover" -map 0:a -map 2:v -c:v mjpeg -disposition:v:0 attached_pic -map_metadata 1 -map_chapters 1)
        else
            cmd+=(-map 0:a -map_metadata 1 -map_chapters 1)
        fi
        cmd+=(-c:a "$AUDIO_CODEC" $AUDIO_QUALITY -movflags +faststart "$output")
        
        echo "Merging and converting..." >&2
        if "${cmd[@]}"; then
            echo "Successfully created: $output" >&2
        else
            echo "Error during merge." >&2
            [[ -f "$output" ]] && rm "$output"
        fi
        rm "$metadata_file" "$concat_file"
    else
        # BATCH CONVERSION
        for input in "${ALL_AUDIO[@]}"; do
            dir=$(dirname "$input"); filename=$(basename "$input")
            output="$dir/${filename%.*}.$OUTPUT_EXT"
            convert_single_file "$input" "$output" "$(find_cover_art "$dir")" METADATA_FROM_INFO
        done
    fi

else
    # --- SINGLE FILE OR FALLBACK ---
    mapfile -d '' ALL_FILES < <(find "$SEARCH_DIR" -maxdepth 1 -type f \( -iname "*.flac" -o -iname "*.mp3" \) -print0)
    for input in "${ALL_FILES[@]}"; do
        dir=$(dirname "$input"); filename=$(basename "$input")
        output="$dir/${filename%.*}.$OUTPUT_EXT"
        convert_single_file "$input" "$output" "$(find_cover_art "$dir")" METADATA_FROM_INFO
    done
fi
